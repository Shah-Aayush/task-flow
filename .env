# TaskFlow Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — only .env.example should be in version control.

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=postgres          # Docker service name (or 'localhost' for local dev)
DB_PORT=5432
DB_USER=taskflow
DB_PASSWORD=taskflow_secret
DB_NAME=taskflow
DB_SSLMODE=disable        # Use 'require' in production

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret — MUST be changed before any production deployment.
# Generate a strong random value with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── Security ─────────────────────────────────────────────────────────────────
# bcrypt cost factor for password hashing. Minimum 12 per spec.
# Higher = slower hashing but more secure. 12 takes ~300ms on modern hardware.
# Do NOT set below 12. Use 10 only in tests to speed up test runs.
BCRYPT_COST=12
